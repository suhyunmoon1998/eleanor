# Required for live voice and structured extraction. Keep this key on the server only.
OPENAI_API_KEY=

# Application
PORT=3000
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=marin
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
EXTRACTION_MODEL=gpt-5-mini
NOISE_REDUCTION=near_field
VAD_EAGERNESS=auto

# Persistent interview records are written here.
SESSION_STORAGE_DIR=storage
MAX_BODY_BYTES=12000000

# Recommended whenever Eleanor is reachable beyond your own computer.
# When APP_PASSWORD is set, the browser will request HTTP Basic credentials.
APP_USERNAME=jacklaw
APP_PASSWORD=
